rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Validation helpers
    function isValidPortfolio(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 64;
    }
    function isValidWatchlist(data) {
      return data.keys().hasAll(['id', 'name', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 64;
    }
    function isValidJournalEntry(data) {
      return data.keys().hasAll(['id', 'title', 'content', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 128 &&
             data.content is string && data.content.size() <= 2048;
    }
    function isValidBag(data) {
      return data.keys().hasAll(['id', 'portfolioId', 'symbol', 'name', 'type', 'shares', 'averageEntry', 'purchaseDate']) &&
             data.id is string && data.id.size() <= 128 &&
             data.portfolioId is string && data.portfolioId.size() <= 128 &&
             data.symbol is string && data.symbol.size() <= 10;
    }
    function isValidRecommendation(data) {
      return data.keys().hasAll(['id', 'ticker', 'contactResourceName', 'sharedAt', 'message']) &&
             data.id is string && data.id.size() <= 128 &&
             data.ticker is string && data.ticker.size() <= 10 &&
             data.contactResourceName is string && data.contactResourceName.size() <= 256 &&
             data.message is string && data.message.size() <= 1024;
    }

    // Routes
    match /users/{userId} {
      match /portfolios/{portfolioId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidPortfolio(request.resource.data);
        allow delete: if isOwner(userId);
      }
      match /watchlists/{watchlistId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidWatchlist(request.resource.data);
        allow delete: if isOwner(userId);
      }
      match /journal/{entryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidJournalEntry(request.resource.data);
        allow delete: if isOwner(userId);
      }
      match /watchlist/{symbol} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      match /alerts/{alertId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      match /bags/{bagId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      match /recommendations/{recommendationId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidRecommendation(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
